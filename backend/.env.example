# Variables de entorno del Backend (FastAPI)
# Copia este archivo como .env y llena los valores reales

# Base de datos PostgreSQL de Railway
DATABASE_URL=postgresql://usuario:password@host:port/dbname

# Orígenes permitidos (CORS) - URL del frontend en Railway/Vercel
ALLOWED_ORIGINS=https://tu-frontend.up.railway.app,http://localhost:5173

# Credenciales de Google Sheets (ruta al archivo JSON de Service Account)
GOOGLE_CREDENTIALS_FILE=./credentials.json
